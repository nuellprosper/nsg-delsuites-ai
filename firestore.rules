rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives & Helpers
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "nuellkelechi@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper to validate string and size
    function isValString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 256 && id.matches('^[a-zA-Z0-9_\\-\\.]+$'); 
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return (!('uid' in data) || isValString(data.uid, 256)) && 
             (!('email' in data) || isValString(data.email, 512)) &&
             (!('role' in data) || data.role in ['admin', 'student']);
    }

    function isValidNote(data) {
      return isValString(data.uid, 256) &&
             (data.uid == request.auth.uid || isAdmin()) &&
             (!('content' in data) || isValString(data.content, 200000));
    }

    function isValidExam(data) {
      return isValString(data.hostUid, 256) && 
             (!('title' in data) || isValString(data.title, 1024)) &&
             (data.hostUid == request.auth.uid || isAdmin());
    }

    function isValidResult(data) {
      return isValString(data.uid, 128) &&
             data.uid == request.auth.uid &&
             data.score is int &&
             data.total is int &&
             data.score <= data.total;
    }

    // --- Collection Rules ---

    // Users Collection
    match /users/{uid} {
      allow get: if isSignedIn();
      allow list: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isOwner(uid) && isValidUser(incoming());
      allow update: if (isOwner(uid) || isAdmin()) && isValidUser(incoming()) && (
        // Action: Profile Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'university', 'level', 'department', 'faculty', 'dob', 'matric', 'matricNumber', 'updatedAt', 'fullName', 'status', 'premiumUntil', 'bypassHostingPayment', 'bypassTakingPayment', 'bypassAllPayments'])) ||
        // Action: Admin Role Update
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role']))
      );
    }

    // Notes Collection
    match /notes/{noteId} {
      allow get: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidNote(incoming());
      allow update: if isSignedIn() && existing().uid == request.auth.uid && isValidNote(incoming()) &&
                   incoming().uid == existing().uid;
      allow delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }

    // Exams & Results (Nested)
    match /exams/{examId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidExam(incoming());
      allow update: if (isAdmin() || (isSignedIn() && existing().hostUid == request.auth.uid)) && isValidExam(incoming());
      allow delete: if isAdmin() || (isSignedIn() && existing().hostUid == request.auth.uid);

      match /results/{resultId} {
        allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || resource.data.hostUid == request.auth.uid || isAdmin());
        allow get: if isSignedIn() && (resource.data.uid == request.auth.uid || resource.data.hostUid == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && isValidResult(incoming());
        allow update, delete: if isAdmin();
      }
    }

    // Blog Posts
    match /blogPosts/{postId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Quizzes (Shared)
    match /quizzes/{quizId} {
      allow read: if true;
      allow create: if isSignedIn() && (incoming().createdBy == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (isSignedIn() && existing().createdBy == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && existing().createdBy == request.auth.uid);
    }

    // User Sub-collections (Private)
    match /users/{uid}/lectureSessions/{sessionId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
    match /users/{uid}/chatSessions/{sessionId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
    match /users/{uid}/studyHistory/{historyId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
    match /users/{uid}/usage/{usageId} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    // Config & Infrastructure
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /email_templates/{templateId} {
      allow read, write: if isAdmin();
    }

    // Test document
    match /test/{docId} {
      allow get: if true;
    }
  }
}
