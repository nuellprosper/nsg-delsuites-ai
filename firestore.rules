rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives & Helpers
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "nuellkelechi@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin')
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Validation Blueprints
    function isValidUser(data) {
      return (data.uid is string) && (data.email is string);
    }

    function isValidExam(data) {
      return (data.get('hostUid', '') is string) &&
             (data.get('id', '') is string) &&
             (!('status' in data) || data.status in ['active', 'ended', 'none']) &&
             (!('questions' in data) || data.questions is list) &&
             (!('registeredStudents' in data) || data.registeredStudents is list);
    }

    // Phase 4: Collection Rules

    // Users Collection
    // allow list is required for matric number lookup and God Mode search
    match /users/{uid} {
      allow get: if true;
      allow list: if true; 
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      match /chatSessions/{sessionId} {
        allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      }
      match /lectureSessions/{sessionId} {
        allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      }
      match /studyHistory/{historyId} {
        allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      }
      match /usage/{today} {
        allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      }
    }

    // Exams & Results
    match /exams/{examId} {
      allow read: if true;
      allow create: if (isAdmin() || (isSignedIn() && incoming().hostUid == request.auth.uid)) && isValidExam(incoming());
      allow update: if (isAdmin() || (isSignedIn() && existing().hostUid == request.auth.uid)) && isValidExam(incoming());
      allow delete: if (isAdmin() || (isSignedIn() && existing().hostUid == request.auth.uid));
      
      match /results/{resultId} {
        allow create: if isSignedIn();
        // Secure list queries by checking resource.data or parent match
        allow read: if isSignedIn() && (
          resource.data.uid == request.auth.uid ||
          resource.data.hostUid == request.auth.uid ||
          isAdmin() ||
          get(/databases/$(database)/documents/exams/$(examId)).data.hostUid == request.auth.uid
        );
      }
    }

    // Quizzes
    match /quizzes/{quizId} {
      allow read: if true;
      allow create, update: if isSignedIn();
    }

    // Blog & Notifications
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if true;
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin();
    }

    // Config & Infrastructure
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /email_templates/{templateId} {
      allow read, write: if isAdmin();
    }
    
    match /registeredStudents/{matric} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Personal Notes
    match /notes/{noteId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (incoming().uid == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin()) && (incoming().uid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // Global Scores & Logs
    match /scoreSheet/{resultId} {
      allow read: if isAdmin();
      allow create: if true; 
    }
    
    match /test/{docId} {
      allow get: if true;
    }
  }
}
